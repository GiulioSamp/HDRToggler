<Window x:Class="HDRToggler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">

    <Border x:Name="Root" CornerRadius="16" Padding="24"
            MouseDown="Root_MouseDown">
        <Border.Background>
            <SolidColorBrush Color="#000000" Opacity="0.82"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.6"
                              BlurRadius="32" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <StackPanel>

            <!-- Title bar -->
            <Grid Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#444444" Margin="0,0,8,0"/>
                    <TextBlock Text="HDR TOGGLER"
                               Foreground="#666666" FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Cursor="Hand" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent"
                                    CornerRadius="6" Width="24" Height="24">
                                <TextBlock x:Name="X" Text="✕"
                                           Foreground="#444444" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF"/>
                                    <Setter TargetName="X"  Property="Foreground" Value="#CCFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Monitor boxes -->
            <ItemsControl x:Name="MonitorList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="28,18" MinWidth="150" Margin="0,0,12,0"
                                Cursor="Hand" MouseLeftButtonDown="MonitorBox_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1AFFFFFF"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HdrEnabled}" Value="True">
                                            <Setter Property="Background" Value="#1A00FF87"/>
                                            <Setter Property="BorderBrush" Value="#4000FF87"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding FriendlyName}"
                                           Foreground="#E0FFFFFF" FontSize="13" FontWeight="Medium"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="11" TextAlignment="Center" FontWeight="SemiBold"
                                          >
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="OFF"/>
                                            <Setter Property="Foreground" Value="#444444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HdrEnabled}" Value="True">
                                                    <Setter Property="Text"       Value="ON"/>
                                                    <Setter Property="Foreground" Value="#00FF87"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>
